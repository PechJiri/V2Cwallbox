{
  "name": {
    "en": "Wallbox Status"
  },
  "description": {
    "en": "Displays current status of V2C Wallbox"
  },
  "height": 180,
  "devices": {
    "type": "app",
    "singular": true,
    "filter": {
      "class": "evcharger"
    }
  },
  "api": {
    "getStatus": {
      "path": "/status",
      "method": "GET"
    },
    "setPaused": {
      "path": "/paused",
      "method": "POST"
    }
  }
}
